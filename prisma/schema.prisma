generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id               String            @id @default(uuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  password         String?
  role             Role              @default(EMPLOYEE)
  status           UserStatus        @default(ACTIVE)
  provider         AuthProvider      @default(LOCAL)
  createdAt        DateTime          @default(now())
  accounts         Account[]
  sessions         Session[]
  supplyRequests   SupplyRequest[]   @relation("SupplyRequester")
  feedbackAuthored Feedback[]        @relation("FeedbackReviewer")
  feedbackReceived Feedback[]        @relation("FeedbackEmployee")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum Role {
  ADMIN
  SUPERVISOR
  EMPLOYEE
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum AuthProvider {
  LOCAL
  GOOGLE
}

enum SupplyStatus {
  PENDING
  APPROVED
  REJECTED
  COMPLETED
}

enum WorkflowStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  REJECTED
}

enum NotificationChannel {
  IN_APP
  EMAIL
}

enum NotificationStatus {
  QUEUED
  SENT
  READ
}

enum JobStatus {
  SCHEDULED
  RUNNING
  COMPLETED
  FAILED
}

enum ReportStatus {
  PENDING
  GENERATED
}

enum ReportFormat {
  CSV
  JSON
  PDF
}

model SupplyRequest {
  id          String       @id @default(uuid())
  item        String
  quantity    Int
  department  String
  status      SupplyStatus @default(PENDING)
  requestDate DateTime     @default(now())
  requesterId String
  requester   User         @relation("SupplyRequester", fields: [requesterId], references: [id], onDelete: Cascade)
}

model Feedback {
  id         String   @id @default(uuid())
  employeeId String
  reviewerId String
  score      Int
  comments   String
  date       DateTime @default(now())
  employee   User     @relation("FeedbackEmployee", fields: [employeeId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("FeedbackReviewer", fields: [reviewerId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id        String   @id @default(uuid())
  actorId   String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
}

model Activity {
  id        String   @id @default(uuid())
  actorId   String
  action    String
  entity    String
  entityId  String
  metadata  Json?
  createdAt DateTime @default(now())
}

model File {
  id         String   @id @default(uuid())
  filename   String
  mimeType   String
  sizeBytes  Int
  uploadedBy String
  createdAt  DateTime @default(now())
}

model Job {
  id        String   @id @default(uuid())
  key       String
  payload   Json?
  runAt     DateTime
  status    JobStatus @default(SCHEDULED)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Notification {
  id          String              @id @default(uuid())
  recipientId String
  title       String
  message     String
  channel     NotificationChannel
  status      NotificationStatus  @default(QUEUED)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

model Report {
  id          String       @id @default(uuid())
  reportKey   String
  format      ReportFormat
  requestedBy String
  status      ReportStatus @default(PENDING)
  filters     Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Setting {
  key       String   @id
  value     String
  updatedBy String
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

model WorkflowInstance {
  id                String         @id @default(uuid())
  entityId          String
  currentStep       String
  status            WorkflowStatus @default(PENDING)
  definitionName    String
  definitionVersion Int
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
}

model RateLimitBucket {
  key       String   @id
  count     Int
  resetAt   DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
